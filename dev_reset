#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

# --- Pretty output helpers ---
if [[ -t 1 ]]; then
  RED=$'\033[0;31m'
  GRN=$'\033[0;32m'
  YEL=$'\033[0;33m'
  BLU=$'\033[0;34m'
  BLD=$'\033[1m'
  RST=$'\033[0m'
else
  RED=""; GRN=""; YEL=""; BLU=""; BLD=""; RST=""
fi

log()  { printf "\n${BLU}${BLD}==>${RST} %s\n" "$*"; }
ok()   { printf "${GRN}✔${RST} %s\n" "$*"; }
warn() { printf "${YEL}⚠${RST} %s\n" "$*"; }
die()  { printf "${RED}✖${RST} %s\n" "$*"; exit 1; }

FRESH=0
if [[ "${1:-}" == "--fresh" ]]; then
  FRESH=1
fi

# --- 1) Restore repo (but keep this script safe once it's tracked) ---
log "Restoring repo (git reset/clean)..."
git reset --hard

# Clean untracked files, but do NOT delete this script (safety for first run)
git clean -fd -e dev_reset

# --- 2) Start Docker Desktop (macOS only) ---
log "Ensuring Docker engine is running..."
if [[ "$(uname -s)" == "Darwin" ]]; then
  if ! docker info >/dev/null 2>&1; then
    log "Starting Docker Desktop (macOS)..."
    open -a Docker || true
  fi
else
  log "Not on macOS (likely inside devcontainer). Skipping 'open -a Docker'."
fi

log "Waiting for Docker engine..."
for i in {1..120}; do
  if docker info >/dev/null 2>&1; then
    log "Docker is ready."
    break
  fi
  sleep 1
  if [[ "$i" == "120" ]]; then
    echo "ERROR: Docker did not become ready."
    echo "If you're in the devcontainer, ensure Docker Desktop is running on your Mac."
    exit 1
  fi
done

# --- 3) Start docker compose services ---
log "Starting docker compose services..."

if [[ "$FRESH" == "1" ]]; then
  log "Fresh mode: stopping and removing compose services..."
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose down -v
    docker-compose up -d --build
  else
    docker compose down -v
    docker compose up -d --build
  fi
else
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose up -d
  else
    docker compose up -d
  fi
fi

# --- 4) Connect VS Code devcontainer to the compose network ---
log "Connecting devcontainer to compose network (if needed)..."

DB_CONTAINER="myapp-db-1"

# Get the network name that the DB container is on (usually myapp_default)
NETWORK_NAME="$(docker inspect -f '{{range $k, $v := .NetworkSettings.Networks}}{{$k}}{{end}}' "$DB_CONTAINER" | awk '{print $1}')"

if [[ -z "${NETWORK_NAME:-}" ]]; then
  echo "ERROR: Could not determine compose network from $DB_CONTAINER"
  exit 1
fi

# Find the devcontainer by VS Code label (most reliable)
DEVCONT_ID="$(docker ps --filter "label=devcontainer.local_folder=${PROJECT_ROOT}" --format '{{.ID}}' | head -n 1)"

if [[ -z "${DEVCONT_ID:-}" ]]; then
  echo "ERROR: Could not find a running VS Code devcontainer for this folder."
  echo "Open VS Code > Reopen in Container, then run ./dev_reset again."
  exit 1
fi

# If not already connected, connect it
if docker inspect -f '{{json .NetworkSettings.Networks}}' "$DEVCONT_ID" | grep -q "\"${NETWORK_NAME}\""; then
  log "Devcontainer already connected to ${NETWORK_NAME}"
else
  docker network connect "${NETWORK_NAME}" "${DEVCONT_ID}" || true
  log "Connected devcontainer to ${NETWORK_NAME}"
fi

# --- 5) Health check: DB container responding ---
log "Health check: waiting for MySQL to accept connections..."

# Read MySQL root password from compose env if available; fallback to common default.
MYSQL_USER="root"
MYSQL_PW="${MYSQL_ROOT_PASSWORD:-password}"

for i in {1..60}; do
  if docker exec myapp-db-1 mysqladmin ping -h 127.0.0.1 -u"${MYSQL_USER}" -p"${MYSQL_PW}" --silent >/dev/null 2>&1; then
    log "MySQL is responding."
    break
  fi
  sleep 1
  if [[ "$i" == "60" ]]; then
    echo "ERROR: MySQL did not become ready."
    exit 1
  fi
done

# --- 6) Verify DB from inside the devcontainer (confirms network + credentials) ---
log "Verify DB from inside devcontainer..."

docker exec -i "${DEVCONT_ID}" bash -lc 'python - <<PY
import os, sys
from sqlalchemy import create_engine, text

db_user = os.environ.get("DB_USER", "root")
db_pw   = os.environ.get("DB_PASSWORD", "")
db_name = os.environ.get("DB_NAME", "")
host    = os.environ.get("DB_HOST", "db")
port    = os.environ.get("DB_PORT", "3306")

# Prefer DATABASE_URL if it exists, otherwise construct it from DB_* vars
url = os.environ.get("DATABASE_URL")
if not url:
  if not db_name:
    print("ERROR: DB_NAME is not set in the devcontainer env.")
    sys.exit(1)
  url = f"mysql+pymysql://{db_user}:{db_pw}@{host}:{port}/{db_name}"

try:
  engine = create_engine(url, pool_pre_ping=True)
  with engine.connect() as conn:
    conn.execute(text("SELECT 1"))
  print("OK: DB reachable from devcontainer")
  print("DB host used:", host)
  print("DB name used:", db_name)
except Exception as e:
  print("ERROR: DB check failed:", e)
  print("Tried URL:", url)
  sys.exit(1)
PY'

# --- 7) Start Flask (inside devcontainer) ---
log "Starting Flask inside devcontainer (if not already running)..."

# If something is already listening on 4000 inside the devcontainer, don't start another Flask
if docker exec "${DEVCONT_ID}" bash -lc "ss -lnt 2>/dev/null | awk '{print \$4}' | grep -q ':4000$'"; then
  log "Flask appears to already be listening on port 4000 inside devcontainer."
else
  # Start Flask in background using your existing script
  docker exec -d "${DEVCONT_ID}" bash -lc "cd /app && nohup /app/scripts/start_flask.sh >/tmp/flask.log 2>&1"
  log "Flask start command sent. Logs: /tmp/flask.log (inside devcontainer)"
fi

# --- 8) HTTP health check (inside devcontainer = reliable) ---
log "Health check: HTTP inside devcontainer on http://127.0.0.1:4000 ..."

for i in {1..30}; do
  if docker exec "${DEVCONT_ID}" bash -lc "curl -fsS --max-time 2 http://127.0.0.1:4000/ >/dev/null"; then
    log "OK: Flask is responding inside devcontainer"
    break
  fi
  sleep 1
  if [[ "$i" == "30" ]]; then
    echo "ERROR: Flask did not respond inside devcontainer."
    echo "Check logs:"
    echo "  docker exec -it ${DEVCONT_ID} bash -lc 'tail -n 120 /tmp/flask.log'"
    exit 1
  fi
done

# Optional: check from Mac (only works if port 4000 is forwarded/exposed)
log "Optional check: Mac -> http://localhost:4000 (may fail if VS Code port-forwarding isn't active)..."
if curl -fsS --max-time 2 "http://localhost:4000" >/dev/null 2>&1; then
  log "OK: Flask reachable from Mac on localhost:4000"
else
  log "Skipping: localhost:4000 not reachable from Mac (this is normal if VS Code port-forwarding isn't active)"
fi

log "Baseline complete."
