#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

# --- Pretty output helpers ---
if [[ -t 1 ]]; then
  RED=$'\033[0;31m'
  GRN=$'\033[0;32m'
  YEL=$'\033[0;33m'
  BLU=$'\033[0;34m'
  BLD=$'\033[1m'
  RST=$'\033[0m'
else
  RED=""; GRN=""; YEL=""; BLU=""; BLD=""; RST=""
fi

log()  { printf "\n${BLU}${BLD}==>${RST} %s\n" "$*"; }
ok()   { printf "${GRN}✔${RST} %s\n" "$*"; }
warn() { printf "${YEL}⚠${RST} %s\n" "$*"; }
die()  { printf "${RED}✖${RST} %s\n" "$*"; exit 1; }

backup_mysql_volume() {
  local volume_name="myapp_mysql-data"
  local backup_dir="${PROJECT_ROOT}/backups"
  local timestamp
  timestamp="$(date +%Y%m%d-%H%M%S)"
  local backup_file="${backup_dir}/${volume_name}-${timestamp}.tgz"

  mkdir -p "$backup_dir"

  if docker volume inspect "$volume_name" >/dev/null 2>&1; then
    log "Creating backup of ${volume_name}..."
    docker run --rm \
      -v "${volume_name}:/from" \
      -v "${backup_dir}:/to" \
      alpine \
      sh -c "cd /from && tar -czf /to/$(basename "$backup_file") ."
    ok "Backup created: ${backup_file}"
  else
    warn "Volume ${volume_name} not found. Skipping backup."
  fi
}

restore_mysql_volume() {
  local volume_name="myapp_mysql-data"
  local backup_dir="${PROJECT_ROOT}/backups"

  local latest_backup
  latest_backup="$(ls -t "${backup_dir}/${volume_name}-"*.tgz 2>/dev/null | head -n 1)"

  if [[ -z "${latest_backup:-}" ]]; then
    die "No backup found in ${backup_dir}"
  fi

  warn "Restoring database from: ${latest_backup}"
  warn "This will overwrite the current ${volume_name} volume."

  read -r -p "Type RESTORE to continue: " CONFIRM
  if [[ "$CONFIRM" != "RESTORE" ]]; then
    die "Restore aborted."
  fi

  log "Stopping compose services..."
  docker compose down || true

  log "Removing existing volume..."
  docker volume rm "${volume_name}" 2>/dev/null || true

  log "Recreating volume..."
  docker volume create "${volume_name}"

  log "Restoring backup..."
  docker run --rm \
    -v "${volume_name}:/to" \
    -v "${backup_dir}:/from" \
    alpine \
    sh -c "cd /to && tar -xzf /from/$(basename "${latest_backup}")"

  ok "Database restored from ${latest_backup}"
}

MODE="run"   # run | status | logs | stop | snapshot-db | restore-db | list-backups
FRESH=0
SAFE=0

confirm_fresh_delete() {
  echo
  warn "DANGER: --fresh will delete Docker volumes, including MySQL data."
  warn "This can erase app data stored in myapp_mysql-data."
  echo
  read -r -p "Type DELETE to continue: " CONFIRM
  if [[ "$CONFIRM" != "DELETE" ]]; then
    die "Aborted. --fresh was not run."
  fi
}

case "${1:-}" in
  "" )
    ;;
  --fresh )
    FRESH=1
    warn "Fresh mode enabled: will recreate compose services (down -v + up --build)"
    confirm_fresh_delete
    ;;
  --safe )
    SAFE=1
    warn "Safe mode enabled: uncommitted changes will be stashed"
    ;;
  --snapshot-db )
    MODE="snapshot-db"
    ;;
  --restore-db )
    MODE="restore-db"
    ;;
  --list-backups )
    MODE="list-backups"
    ;;
  --status )
    MODE="status"
    ;;
  --logs )
    MODE="logs"
    ;;
  --stop )
    MODE="stop"
    ;;
  --doctor )
    MODE="doctor"
    ;;
  -h|--help )
    cat <<'USAGE'
Usage:
  ./dev_reset           Restore + start everything + verify
  ./dev_reset --fresh   Full rebuild (down -v + up --build)
  ./dev_reset --status  Show environment status only
  ./dev_reset --logs    Show recent logs (flask + db)
  ./dev_reset --stop    Stop compose services (and leave repo untouched)
  ./dev_reset --restore-db  Restore the latest MySQL volume backup
  ./dev_reset --list-backups  List available MySQL volume backups
USAGE
    exit 0
    ;;
  * )
    die "Unknown option: ${1}. Use --help."
    ;;
esac

# Early Exit Commands
# --- Helper: find devcontainer id (best-effort) ---
find_devcontainer() {
  docker ps --filter "label=devcontainer.local_folder=${PROJECT_ROOT}" --format '{{.ID}}' | head -n 1
}


# --- MODE: snapshot-db ---
if [[ "$MODE" == "snapshot-db" ]]; then
  log "Creating database snapshot..."
  backup_mysql_volume
  ok "Snapshot complete."
  exit 0
fi

# --- MODE: restore-db ---
if [[ "$MODE" == "restore-db" ]]; then
  log "Restoring latest database snapshot..."
  restore_mysql_volume
  ok "Restore complete."
  exit 0
fi

# --- MODE: list-backups ---
if [[ "$MODE" == "list-backups" ]]; then
  log "Available database backups"

  backup_dir="${PROJECT_ROOT}/backups"

  if [[ ! -d "$backup_dir" ]]; then
    warn "No backups directory found."
    exit 0
  fi

  ls -lh "$backup_dir"/myapp_mysql-data-*.tgz 2>/dev/null || warn "No backups found."

  exit 0
fi

# --- MODE: stop ---
if [[ "$MODE" == "stop" ]]; then
  log "Stopping docker compose services..."
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose down
  else
    docker compose down
  fi
  ok "Stopped."
  exit 0
fi

# --- MODE: doctor ---
if [[ "$MODE" == "doctor" ]]; then
  log "Running environment diagnostics..."

  echo

  # Docker check
  if docker info >/dev/null 2>&1; then
    ok "Docker engine is running"
  else
    die "Docker engine is NOT running"
  fi

  # Containers
  if docker ps --format '{{.Names}}' | grep -q "myapp-db-1"; then
    ok "MySQL container detected"
  else
    warn "MySQL container not running"
  fi

  if docker ps --format '{{.Names}}' | grep -q "myapp-adminer-1"; then
    ok "Adminer container detected"
  else
    warn "Adminer container not running"
  fi

  # Devcontainer
  DEVCONT_ID="$(find_devcontainer || true)"

  if [[ -n "$DEVCONT_ID" ]]; then
    ok "Devcontainer running ($DEVCONT_ID)"
  else
    warn "Devcontainer not detected"
  fi

  # Network
  if docker network inspect myapp_default >/dev/null 2>&1; then
    ok "Docker network myapp_default exists"
  else
    warn "Docker network myapp_default missing"
  fi

  # Flask
  if [[ -n "$DEVCONT_ID" ]]; then
    if docker exec "$DEVCONT_ID" ss -lnt | grep -q ":4000"; then
      ok "Flask process listening on port 4000"
    else
      warn "Flask not listening on port 4000"
    fi
  fi

  # HTTP check
  if curl -fsS --max-time 2 http://localhost:4000 >/dev/null 2>&1; then
    ok "Flask reachable from Mac"
  else
    warn "Flask not reachable from Mac (port forwarding may be off)"
  fi

  echo
  ok "Doctor check complete"

  exit 0
fi

# --- MODE: status ---
if [[ "$MODE" == "status" ]]; then
  log "Environment Status"
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" --filter "name=myapp-" || true
  DEVCONT_ID="$(find_devcontainer || true)"
  if [[ -n "${DEVCONT_ID:-}" ]]; then
    ok "Devcontainer ID: ${DEVCONT_ID}"
  else
    warn "Devcontainer not found (VS Code may not be open / not running)"
  fi
  exit 0
fi

# --- MODE: logs ---
if [[ "$MODE" == "logs" ]]; then
  log "Recent logs"

  log "Compose status"
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose ps
  else
    docker compose ps
  fi

  DEVCONT_ID="$(find_devcontainer || true)"
  if [[ -n "${DEVCONT_ID:-}" ]]; then
    log "Flask (/tmp/flask.log)"
    docker exec -it "${DEVCONT_ID}" bash -lc "tail -n 120 /tmp/flask.log 2>/dev/null || echo 'No /tmp/flask.log yet'"
  else
    warn "Devcontainer not found, cannot show /tmp/flask.log"
  fi

  log "MySQL container logs (myapp-db-1) - last 120 lines"
  docker logs --tail 120 myapp-db-1 2>/dev/null || warn "No db logs or container not running"

  log "MySQL container logs (filtered: error/warn)"
  docker logs --tail 300 myapp-db-1 2>/dev/null | egrep -i "error|warn|fatal|denied|fail" || echo "(no errors found)"

  exit 0
fi

# --- 1) Restore repo (but keep this script safe once it's tracked) ---
log "Restoring repo (git reset/clean)..."

if [[ "$SAFE" == "1" ]]; then
  warn "Saving uncommitted work with git stash"
  git stash push -u -m "dev_reset safety stash"
fi

git reset --hard
git clean -fd

if [[ "$SAFE" == "1" ]]; then
  warn "Restoring stashed work"
  git stash pop || warn "No stash to restore"
fi

# --- 2) Start Docker Desktop (macOS only) ---
log "Ensuring Docker engine is running..."
if [[ "$(uname -s)" == "Darwin" ]]; then
  if ! docker info >/dev/null 2>&1; then
    log "Starting Docker Desktop (macOS)..."
    open -a Docker || true
  fi
else
  log "Not on macOS (likely inside devcontainer). Skipping 'open -a Docker'."
fi

log "Waiting for Docker engine..."
for i in {1..120}; do
  if docker info >/dev/null 2>&1; then
    log "Docker is ready."
    break
  fi
  sleep 1
  if [[ "$i" == "120" ]]; then
    die "ERROR: Docker did not become ready."
    echo "If you're in the devcontainer, ensure Docker Desktop is running on your Mac."
    exit 1
  fi
done

# --- 3) Start docker compose services ---
log "Starting docker compose services..."

if [[ "$FRESH" == "1" ]]; then
  backup_mysql_volume
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose down -v
    docker-compose up -d --build
  else
    docker compose down -v
    docker compose up -d --build
  fi
else
  if command -v docker-compose >/dev/null 2>&1; then
    docker-compose up -d
  else
    docker compose up -d
  fi
fi

# --- 4) Connect VS Code devcontainer to the compose network ---
log "Connecting devcontainer to compose network (if needed)..."

DB_CONTAINER="myapp-db-1"

# Get the network name that the DB container is on (usually myapp_default)
NETWORK_NAME="$(docker inspect -f '{{range $k, $v := .NetworkSettings.Networks}}{{$k}}{{end}}' "$DB_CONTAINER" | awk '{print $1}')"

if [[ -z "${NETWORK_NAME:-}" ]]; then
  die "ERROR: Could not determine compose network from $DB_CONTAINER"
  exit 1
fi

# Find the devcontainer by VS Code label (most reliable)
DEVCONT_ID="$(docker ps --filter "label=devcontainer.local_folder=${PROJECT_ROOT}" --format '{{.ID}}' | head -n 1)"

if [[ -z "${DEVCONT_ID:-}" ]]; then
  die "ERROR: Could not find a running VS Code devcontainer for this folder."
  echo "Open VS Code > Reopen in Container, then run ./dev_reset again."
  exit 1
fi

# If not already connected, connect it
if docker inspect -f '{{json .NetworkSettings.Networks}}' "$DEVCONT_ID" | grep -q "\"${NETWORK_NAME}\""; then
  log "Devcontainer already connected to ${NETWORK_NAME}"
else
  docker network connect "${NETWORK_NAME}" "${DEVCONT_ID}" || true
  log "Connected devcontainer to ${NETWORK_NAME}"
fi

# --- 5) Health check: DB container responding ---
log "Health check: waiting for MySQL to accept connections..."

# Read MySQL root password from compose env if available; fallback to common default.
MYSQL_USER="root"
MYSQL_PW="${MYSQL_ROOT_PASSWORD:-password}"

for i in {1..60}; do
  if docker exec myapp-db-1 mysqladmin ping -h 127.0.0.1 -u"${MYSQL_USER}" -p"${MYSQL_PW}" --silent >/dev/null 2>&1; then
    log "MySQL is responding."
    break
  fi
  sleep 1
  if [[ "$i" == "60" ]]; then
    die "ERROR: MySQL did not become ready."
    exit 1
  fi
done

# --- 6) Verify DB from inside the devcontainer (confirms network + credentials) ---
log "Verify DB from inside devcontainer..."

docker exec -i "${DEVCONT_ID}" bash -lc 'python - <<PY
import os, sys
from sqlalchemy import create_engine, text

db_user = os.environ.get("DB_USER", "root")
db_pw   = os.environ.get("DB_PASSWORD", "")
db_name = os.environ.get("DB_NAME", "")
host    = os.environ.get("DB_HOST", "db")
port    = os.environ.get("DB_PORT", "3306")

# Prefer DATABASE_URL if it exists, otherwise construct it from DB_* vars
url = os.environ.get("DATABASE_URL")
if not url:
  if not db_name:
    print("ERROR: DB_NAME is not set in the devcontainer env.")
    sys.exit(1)
  url = f"mysql+pymysql://{db_user}:{db_pw}@{host}:{port}/{db_name}"

try:
  engine = create_engine(url, pool_pre_ping=True)
  with engine.connect() as conn:
    conn.execute(text("SELECT 1"))
  print("OK: DB reachable from devcontainer")
  print("DB host used:", host)
  print("DB name used:", db_name)
except Exception as e:
  print("ERROR: DB check failed:", e)
  print("Tried URL:", url)
  sys.exit(1)
PY'

# --- 7) Start Flask (inside devcontainer) ---
log "Starting Flask inside devcontainer (if not already running)..."

# If something is already listening on 4000 inside the devcontainer, don't start another Flask
if docker exec "${DEVCONT_ID}" bash -lc "ss -lnt 2>/dev/null | awk '{print \$4}' | grep -q ':4000$'"; then
  log "Flask appears to already be listening on port 4000 inside devcontainer."
else
  # Start Flask in background using your existing script
  docker exec -d "${DEVCONT_ID}" bash -lc "cd /app && nohup /app/scripts/start_flask.sh >/tmp/flask.log 2>&1"
  log "Flask start command sent. Logs: /tmp/flask.log (inside devcontainer)"
fi

# --- 8) HTTP health check (inside devcontainer = reliable) ---
log "Health check: HTTP inside devcontainer on http://127.0.0.1:4000 ..."

for i in {1..30}; do
  if docker exec "${DEVCONT_ID}" bash -lc "curl -fsS --max-time 2 http://127.0.0.1:4000/ >/dev/null"; then
    log "OK: Flask is responding inside devcontainer"
    break
  fi
  sleep 1
  if [[ "$i" == "30" ]]; then
    die "ERROR: Flask did not respond inside devcontainer."
    echo "Check logs:"
    echo "  docker exec -it ${DEVCONT_ID} bash -lc 'tail -n 120 /tmp/flask.log'"
    exit 1
  fi
done

# Optional: check from Mac (only works if port 4000 is forwarded/exposed)
log "Optional check: Mac -> http://localhost:4000 (may fail if VS Code port-forwarding isn't active)..."
if curl -fsS --max-time 2 "http://localhost:4000" >/dev/null 2>&1; then
  log "OK: Flask reachable from Mac on localhost:4000"
else
  log "Skipping: localhost:4000 not reachable from Mac (this is normal if VS Code port-forwarding isn't active)"
fi

log "Environment Status"

# Containers
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" \
  --filter "name=myapp-" || true

echo

# Network + Devcontainer
ok "Compose network: ${NETWORK_NAME}"
ok "Devcontainer ID: ${DEVCONT_ID}"

# URLs (if exposed/forwarded)
if curl -fsS --max-time 2 "http://localhost:4000" >/dev/null 2>&1; then
  ok "Flask URL:   http://localhost:4000"
else
  warn "Flask URL: http://localhost:4000 (not reachable from Mac; VS Code port-forward may be off)"
fi

if curl -fsS --max-time 2 "http://localhost:8081" >/dev/null 2>&1; then
  ok "Adminer URL: http://localhost:8081"
else
  warn "Adminer URL: http://localhost:8081 (not reachable from Mac)"
fi

ok "dev_reset finished ✅"
